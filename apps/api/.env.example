# ─── Banco de Dados PostgreSQL ────────────────────────────────────────────────
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL=postgresql://lotus_user:SUA_SENHA_AQUI@localhost:5432/lotus_tef

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Coloque o domínio exato onde o frontend está rodando
CORS_ORIGIN=https://painel.lotustef.com

# ─── Segurança (gere valores aleatórios longos para produção) ─────────────────
# Gerar: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque-por-uma-string-aleatoria-longa-aqui
SESSION_SECRET=troque-por-outra-string-aleatoria-longa-aqui

# ─── Evolution API (WhatsApp) — preencha quando for usar ──────────────────────
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua-chave-aqui
